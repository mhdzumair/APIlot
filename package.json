{
  "name": "apilot",
  "version": "2.3.0",
  "description": "Your AI copilot for API testing - supports GraphQL and REST with AI-powered mocking, time-travel debugging and performance analytics",
  "keywords": [
    "graphql",
    "rest-api",
    "api-testing",
    "ai-mock",
    "copilot",
    "testing",
    "debugging",
    "firefox",
    "chrome",
    "extension",
    "browser-extension",
    "developer-tools",
    "qa",
    "mocking",
    "monitoring",
    "performance-analytics",
    "time-travel-debugging",
    "manifest-v2",
    "manifest-v3"
  ],
  "author": "Mohamed Zumair",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mhdzumair/apilot"
  },
  "bugs": {
    "url": "https://github.com/mhdzumair/apilot/issues"
  },
  "homepage": "https://github.com/mhdzumair/apilot#readme",
  "scripts": {
    "dev": "wxt -b firefox",
    "dev:firefox": "wxt -b firefox",
    "dev:chrome": "wxt -b chrome",
    "build": "wxt build -b firefox && wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "build:chrome": "wxt build -b chrome",
    "package": "wxt zip -b firefox && wxt zip -b chrome",
    "package:firefox": "wxt zip -b firefox",
    "package:chrome": "wxt zip -b chrome",
    "clean": "rm -rf dist .wxt",
    "lint": "eslint src entrypoints",
    "lint:fix": "eslint src entrypoints --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "playwright:extension": "node scripts/playwright-with-apilot.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "highlight.js": "^11.11.1",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "webextension-polyfill": "^0.12.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@wxt-dev/module-react": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lucide-react": "^1.7.0",
    "playwright": "^1.59.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "wxt": "^0.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
